[gd_scene load_steps=2 format=3 uid="uid://j1hnt7daci8l"]

[sub_resource type="GDScript" id="GDScript_cxg15"]
script/source = "extends Node2D

@onready var timer = $Timer

func _ready() -> void:
	timer.start(0.25)

func _physics_process(delta: float) -> void:
	if(timer.is_stopped()):
		get_parent().propogate_growth()
		queue_free()
"

[node name="TreeGrowthProcess" type="Node2D"]
script = SubResource("GDScript_cxg15")

[node name="Timer" type="Timer" parent="."]
one_shot = true
